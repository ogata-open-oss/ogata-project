{
  "name": "ogata-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Your own R2/KV/D1 storage connector for Claude — a remote MCP server on Cloudflare Workers, OAuth-gated to a single GitHub account.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy && wrangler d1 migrations apply lemurkit-metadata --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "0.7.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.13.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260527.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wrangler": "4.107.0"
  }
}
