# Dependency pinning
save-exact=true
engine-strict=true
auto-install-peers=false

# Supply-chain hardening
# Resolve every package from the official registry, so a stray local or
# dependency-supplied config can't silently redirect installs to a mirror. The
# scripts/check-pnpm-registry.sh guard independently verifies resolved tarball
# URLs in the lockfile; this is the install-time half of the same guarantee.
registry=https://registry.npmjs.org/
# Run NO dependency lifecycle scripts on install. Stronger than pnpm 10's
# default-deny (which still runs an onlyBuiltDependencies allowlist): a Worker
# is bundled by esbuild/wrangler at build time and needs no native install-time
# builds, so we can afford the blanket deny. NEVER replace this with
# `dangerously-allow-all-builds` — the hygiene guard enforces its absence.
ignore-scripts=true
# Refuse versions published less than 3 days ago (unit: MINUTES, so 4320 = 3 days).
# Defends against freshly-published malicious releases; use `minimumReleaseAgeExclude`
# in pnpm-workspace.yaml to opt specific packages out if ever needed.
minimum-release-age=4320
# Severity gate for `pnpm audit`.
audit-level=moderate
